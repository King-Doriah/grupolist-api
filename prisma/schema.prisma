generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Roles {
  ADMIN
  OWNER
}

enum Plan {
  FREE
  PRO
}

model User {
  id          String    @id @default(uuid())
  nome        String
  email       String?   @unique
  telefone    Int       @unique
  senha       String
  token       String?   @db.Text
  role        Roles     @default(OWNER)
  plan        Plan?
  planExpires DateTime?
  level       Int       @default(3)
  ativo       Boolean   @default(true)
  createdAt   DateTime  @default(now())
  lists       List[]

  @@map("usuarios")
}

enum ListStatus {
  OPEN
  PURCHASED
  ON_PROCESS
  FINISHED
}

model List {
  id         String     @id @default(uuid())
  produto    String
  foto       String
  status     ListStatus @default(OPEN)
  disponivel Boolean    @default(false)
  token      String     @unique
  //dataPrevista DateTime
  createdAt  DateTime   @default(now())

  //Relacionamento
  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@map("listas")
}

model Faq {
  id        String   @id @default(uuid())
  pergunta  String   @unique
  resposta  String   @unique @db.Text
  createdAt DateTime @default(now())

  @@map("faqs")
}

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_reset")
}
